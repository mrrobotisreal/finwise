# FinWise frontend environment. Copy to .env and fill in.
# VITE_* values are public-by-design client config; the real security boundary is
# the Firebase ID-token verification + email allowlist on finwise-api.

# Base URL of the Go API (finwise-api).
VITE_API_BASE_URL=http://localhost:8095

# Firebase web app config (Project settings → General → Your apps → Web).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=finwise-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=finwise-prod
VITE_FIREBASE_APP_ID=
